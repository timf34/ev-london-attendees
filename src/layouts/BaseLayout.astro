---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Attendee Directory",
  description = "Simple public attendee directory",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="wrapper">
      <slot />
    </div>
  </body>
</html>
