---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import { listProfiles } from "@/lib/profiles";

let profiles = [];
let loadError: string | null = null;
const deleted = Astro.url.searchParams.get("deleted") === "1";

try {
  profiles = await listProfiles();
} catch (error) {
  loadError = error instanceof Error ? error.message : "Unable to load profiles.";
}
---

<BaseLayout title="Attendee Directory">
  <main>
    <header class="toolbar">
      <h1>Attendee Directory</h1>
      <a class="link" href="/create">Create profile</a>
    </header>

    {deleted ? <p class="notice success">Profile deleted.</p> : null}

    {loadError ? (
      <p class="muted">{loadError}</p>
    ) : profiles.length === 0 ? (
      <p class="muted">No profiles yet.</p>
    ) : (
      <section class="grid">
        {profiles.map((profile) => (
          <article class="card card-row">
            {profile.photo_url ? (
              <img
                src={profile.photo_url}
                alt={profile.name}
                class="profile-photo"
                loading="lazy"
              />
            ) : (
              <span class="profile-photo-placeholder" aria-hidden="true"></span>
            )}

            <div class="card-copy">
              <h2>{profile.name}</h2>
              <p>{profile.about_me}</p>

              <div class="meta">
                {profile.linkedin_url ? (
                  <a href={profile.linkedin_url} target="_blank" rel="noreferrer">
                    LinkedIn
                  </a>
                ) : null}

                {profile.twitter_url ? (
                  <a href={profile.twitter_url} target="_blank" rel="noreferrer">
                    X / Twitter
                  </a>
                ) : null}

                {profile.public_email ? (
                  <a href={`mailto:${profile.public_email}`}>Email</a>
                ) : null}
              </div>
            </div>
          </article>
        ))}
      </section>
    )}
  </main>
</BaseLayout>
