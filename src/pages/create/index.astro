---
export const prerender = false;

import ProfileForm from "@/components/ProfileForm.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const error = Astro.url.searchParams.get("error");
---

<BaseLayout title="Create Profile | EV London">
  <main class="page-stack">
    <section class="page-head page-head--narrow">
      <h1>Create your profile</h1>
    </section>
    <section class="notice notice-tip">
      <p>
        <strong>Include your X link to auto-populate your profile photo.</strong>
        Otherwise, upload one yourself.
      </p>
      <p>
        <strong>Save your private edit link after creating your profile.</strong>
        You will need it later if you want to edit or delete your profile.
      </p>
    </section>
    <ProfileForm
      action="/api/profiles/create"
      submitLabel="Create profile"
      photoLabel="Profile picture (optional)"
      photoNote="If you add an X / Twitter URL and skip upload, we will try to use that profile photo automatically."
      error={error}
    />
  </main>
</BaseLayout>
