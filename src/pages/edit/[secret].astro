---
export const prerender = false;

import ProfileForm from "@/components/ProfileForm.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { findProfileByEditSecretHash } from "@/lib/profiles";
import { hashEditSecret } from "@/lib/secrets";

const secret = Astro.params.secret ?? "";
const error = Astro.url.searchParams.get("error");
const saved = Astro.url.searchParams.get("saved") === "1";
const profile = secret
  ? await findProfileByEditSecretHash(hashEditSecret(secret))
  : null;
---

<BaseLayout title="Edit Profile">
  <main>
    {profile ? (
      <>
        <h1>Edit profile</h1>
        {saved ? <p class="small">Changes saved.</p> : null}
        <ProfileForm
          action={`/api/profiles/${secret}`}
          submitLabel="Save profile"
          photoLabel="Replace profile picture (optional)"
          photoNote="If you do not upload a new file and the profile still has no photo, we can try X again. LinkedIn photo autofill is not reliable, so upload manually if needed."
          error={error}
          values={profile}
        />
        <section class="card danger-zone">
          <h2>Delete profile</h2>
          <p class="small">
            This permanently removes the profile from the public directory.
          </p>
          <form
            method="POST"
            action={`/api/profiles/${secret}/delete`}
            onsubmit="return confirm('Delete this profile permanently?');"
          >
            <button type="submit" class="danger">Delete profile</button>
          </form>
        </section>
      </>
    ) : (
      <>
        <h1>Invalid edit link</h1>
        <p class="muted">No matching profile found for this link.</p>
        <a class="link" href="/">Back to directory</a>
      </>
    )}
  </main>
</BaseLayout>
