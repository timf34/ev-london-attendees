{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "noEmit": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler"
  },
  "include": [
    ".astro/types.d.ts",
    "src/**/*",
    "supabase/**/*.ts",
    "supabase/**/*.sql"
  ],
  "exclude": [
    "node_modules"
  ]
}
